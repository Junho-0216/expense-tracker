# 생성: 2026-05-04
# 사용법: 이 파일을 `.env`로 복사하여 값을 채우세요.
#   PowerShell: Copy-Item env.example .env
# `.env`는 `.gitignore`로 보호됩니다.

# 사본 시트 ID (Phase 7에서 실 시트 ID로 교체)
SHEET_ID=<TEST_COPY_SHEET_ID>
SHEET_TAB=Sheet1

# Drive 폴더 ID (FE/Worker와 동일해야 함)
DRIVE_FOLDER_ID=<DRIVE_FOLDER_ID>

# SA 키 경로 (기본: %APPDATA%\expense_tracker\sa.json)
# 절대경로 지정 시 우선 적용.
# SA_JSON_PATH=

# Flask 포트 (기본 8765)
# ADMIN_PORT=8765
